#!/bin/zsh
# BalloonParty pre-push hook — run the EditMode suite before pushing.
# Install: cp Tools/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
# (or once: git config core.hooksPath Tools, to track the hook in-repo)
#
# Batchmode can't run while the Unity editor holds the project lock, so this
# only runs when the editor is CLOSED. With the editor open the push is allowed
# through — run 'Tools > BalloonParty > Run EditMode Tests' manually if you want
# to check first.

ROOT="$(git rev-parse --show-toplevel)"

if [ -f "$ROOT/Temp/UnityLockfile" ]; then
    echo "🎈 Unity editor open — skipping the pre-push test run."
    exit 0
fi

echo "🎈 Editor closed — running EditMode tests (batchmode)…"
"$ROOT/Tools/run_editmode_tests.sh" --force
if [ $? -ne 0 ]; then
    echo "❌ EditMode tests failed — push blocked. See Tools/last-test-run.md"
    exit 1
fi

echo "✅ EditMode tests green."
exit 0
