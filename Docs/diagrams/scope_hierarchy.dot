digraph ScopeHierarchy {
    rankdir=TB;
    bgcolor="transparent";
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box];
    edge [fontname="Helvetica", fontsize=8, color="#30363d"];

    Game [label="GameLifetimeScope\n(composition root)\n[DefaultExecutionOrder(-5001)]", fillcolor="#1f3a5f", fontcolor="#58a6ff"];

    Thrower [label="ThrowerLifetimeScope\n(Thrower GameObject)", fillcolor="#2a2a2a", fontcolor="#c9d1d9"];
    ScoreUI [label="ScoreUILifetimeScope\n(Score HUD canvas)", fillcolor="#2a2a2a", fontcolor="#c9d1d9"];
    LevelUp [label="LevelUpLifetimeScope\n(LevelUp popup)", fillcolor="#2a2a2a", fontcolor="#c9d1d9"];
    ShieldUI [label="ShieldUILifetimeScope\n(Shield HUD)", fillcolor="#2a2a2a", fontcolor="#c9d1d9"];

    Balloon [label="BalloonLifetimeScope ×N\n(autoRun=false)\nInjectingPoolChannel", fillcolor="#3d2a1a", fontcolor="#f78166", style="filled,rounded,dashed"];
    Projectile [label="ProjectileLifetimeScope\n(autoRun=false)\nInjectingPoolChannel", fillcolor="#3d2a1a", fontcolor="#f78166", style="filled,rounded,dashed"];

    Launch [label="LaunchLifetimeScope\n(Launcher scene)", fillcolor="#1a3a1a", fontcolor="#3fb950"];

    Game -> Thrower;
    Game -> ScoreUI;
    Game -> LevelUp;
    Game -> ShieldUI;
    Game -> Balloon;
    Game -> Projectile;

    // Singletons
    subgraph cluster_singletons {
        label="Registered Singletons";
        style="dashed"; color="#30363d"; fontcolor="#8b949e"; fontname="Helvetica"; fontsize=9;
        node [shape=ellipse, fillcolor="#161b22", fontcolor="#8b949e", fontsize=8];
        SlotGrid [label="SlotGrid"];
        PoolMgr [label="PoolManager"];
        PathHolder [label="BalancePathHolder"];
        PauseSvc [label="PauseService"];
        NudgeRes [label="NudgeOverrideResolver"];
        StreakTrack [label="ColorStreakTracker"];
    }

    Game -> SlotGrid [style=dotted, color="#30363d"];
    Game -> PoolMgr [style=dotted, color="#30363d"];
    Game -> PathHolder [style=dotted, color="#30363d"];
}

