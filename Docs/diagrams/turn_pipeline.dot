digraph TurnPipeline {
    rankdir=TB;
    bgcolor="transparent";
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box];
    edge [fontname="Helvetica", fontsize=8];

    // Phases
    Hit [label="1. Hit Phase\n─────────\nProjectile bounces\nPops/deflects balloons\nNeighbors nudge", fillcolor="#3d2a1a", fontcolor="#f78166"];
    Balance [label="2. Balance Phase\n─────────\nBalance() consolidates\nexisting balloons upward\nTransit slots reserved\nin BalancePathHolder", fillcolor="#1f3a5f", fontcolor="#58a6ff"];
    Spawn [label="3. Spawn Phase\n─────────\nNew balloon lines spawn\nComputePath checks\nBalancePathHolder", fillcolor="#1a3a1a", fontcolor="#3fb950"];
    PostBalance [label="4. Post-Spawn Balance\n─────────\nDeferred balance pass\n(next frame)\nBalanceBalloonsMessage", fillcolor="#2d1f3d", fontcolor="#d2a8ff"];

    // Triggers
    ProjectileDeath [label="Projectile Death\nProjectileDestroyedMessage", fillcolor="#2a2a2a", fontcolor="#8b949e", shape=ellipse];
    BalanceMsg [label="BalanceBalloonsMessage", fillcolor="#2a2a2a", fontcolor="#8b949e", shape=ellipse];

    Hit -> ProjectileDeath [label="shields = 0", color="#f78166", fontcolor="#8b949e"];
    ProjectileDeath -> Balance [color="#58a6ff"];
    Balance -> Spawn [label="grid updated", color="#3fb950", fontcolor="#8b949e"];
    Spawn -> BalanceMsg [color="#d2a8ff"];
    BalanceMsg -> PostBalance [color="#d2a8ff"];
}

