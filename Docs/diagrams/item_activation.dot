digraph ItemActivation {
    rankdir=TB;
    bgcolor="transparent";
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box];
    edge [fontname="Helvetica", fontsize=8];

    Collision [label="ProjectileView\nOnTriggerEnter2D", fillcolor="#3d2a1a", fontcolor="#f78166", shape=ellipse];
    HitMsg [label="ActorHitMessage\n(Damage=1)", fillcolor="#2a2a2a", fontcolor="#c9d1d9", shape=hexagon];
    BalloonHide [label="BalloonController\nHide() balloon\nwait ItemActivatedMsg", fillcolor="#1f3a5f", fontcolor="#58a6ff"];
    Yield [label="ItemActivator\nyield 1 frame", fillcolor="#2d1f3d", fontcolor="#d2a8ff"];
    Setup [label="Setup(balloon, worldPos)\nawait Activate()", fillcolor="#2d1f3d", fontcolor="#d2a8ff"];

    // Handlers
    subgraph cluster_handlers {
        label="Item Handlers"; style="dashed"; color="#30363d"; fontcolor="#8b949e"; fontname="Helvetica";
        Bomb [label="💣 Bomb\nOverlapCircleAll\nnudge + destroy", fillcolor="#1a3a1a", fontcolor="#3fb950"];
        Laser [label="🔫 Laser\n4× CircleCastAll\nrotated beams", fillcolor="#1a3a1a", fontcolor="#3fb950"];
        Lightning [label="⚡ Lightning\nChain same-color\nfractal bolts", fillcolor="#1a3a1a", fontcolor="#3fb950"];
        Paint [label="🎨 Paint\nHex neighbor arcs\nrecolor IPaintable", fillcolor="#1a3a1a", fontcolor="#3fb950"];
        Shield [label="🛡️ Shield\n+1 ShieldsRemaining\non projectile", fillcolor="#1a3a1a", fontcolor="#3fb950"];
    }

    SecondaryHits [label="ActorHitMessage\nper secondary balloon\n(Damage=settings.Damage)", fillcolor="#2a2a2a", fontcolor="#c9d1d9", shape=hexagon];
    ActivatedMsg [label="ItemActivatedMessage", fillcolor="#2a2a2a", fontcolor="#c9d1d9", shape=hexagon];
    ReturnPool [label="BalloonController\nreturns balloon to pool", fillcolor="#1f3a5f", fontcolor="#58a6ff"];

    Collision -> HitMsg [color="#f78166"];
    HitMsg -> BalloonHide [color="#58a6ff"];
    HitMsg -> Yield [color="#d2a8ff"];
    Yield -> Setup [color="#d2a8ff"];
    Setup -> Bomb [style=dashed, color="#30363d"];
    Setup -> Laser [style=dashed, color="#30363d"];
    Setup -> Lightning [style=dashed, color="#30363d"];
    Setup -> Paint [style=dashed, color="#30363d"];
    Setup -> Shield [style=dashed, color="#30363d"];
    Bomb -> SecondaryHits [color="#3fb950"];
    Laser -> SecondaryHits [color="#3fb950"];
    Lightning -> SecondaryHits [color="#3fb950"];
    Paint -> SecondaryHits [color="#3fb950", style=dashed, label="(no hit)"];
    Setup -> ActivatedMsg [color="#d2a8ff"];
    ActivatedMsg -> ReturnPool [color="#58a6ff"];
}

