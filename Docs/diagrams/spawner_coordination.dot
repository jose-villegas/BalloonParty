digraph SpawnerCoordination {
    rankdir=TB;
    bgcolor="transparent";
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box];
    edge [fontname="Helvetica", fontsize=8];

    Gate [label="NavigationReadyGate\nopens", fillcolor="#3d2a1a", fontcolor="#f78166", shape=diamond];

    Stage0 [label="SpawnStage.StaticActors (0)\n─────────\nStaticActorSpawner.SpawnAsync", fillcolor="#1f3a5f", fontcolor="#58a6ff"];
    Stage50 [label="SpawnStage.DynamicActors (50)\n─────────\n(future GridSpawner)", fillcolor="#2a2a2a", fontcolor="#8b949e", style="filled,rounded,dashed"];
    Stage100 [label="SpawnStage.BalloonActors (100)\n─────────\nBalloonSpawner.SpawnAsync", fillcolor="#1a3a1a", fontcolor="#3fb950"];

    Gate -> Stage0 [color="#f78166"];
    Stage0 -> Stage50 [label="await", color="#30363d", fontcolor="#8b949e"];
    Stage50 -> Stage100 [label="await", color="#30363d", fontcolor="#8b949e"];

    // Parallel note
    Parallel [label="Spawners within same\nstage run in parallel\n(UniTask.WhenAll)", fillcolor="transparent", fontcolor="#8b949e", shape=note, style=""];
    Stage0 -> Parallel [style=invis];
}

